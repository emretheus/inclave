{
  "name": "inclave-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "InClave desktop — JS/Rust side of the monorepo (Tauri + React + Tailwind + shadcn).",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @inclave/desktop dev",
    "tauri": "pnpm --filter @inclave/desktop tauri",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "gen:ipc": "pnpm --filter @inclave/ipc-contract gen"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
