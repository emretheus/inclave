{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InClave",
  "version": "0.1.0",
  "identifier": "com.inclave.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "pnpm --filter @inclave/desktop dev",
    "beforeBuildCommand": "pnpm --filter @inclave/desktop build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "InClave",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "hardenedRuntime": true
    },
    "resources": {
      "binaries/inclave-bridge": "inclave-bridge",
      "binaries/sandbox-runtime": "sandbox-runtime"
    }
  }
}
